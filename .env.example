# Deepseek API Configuration
DEEPSEEK_API_KEY=

# Twilio — Llamadas con IA
# Crea cuenta en https://www.twilio.com → Console → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+34xxxxxxxxx   # Número Twilio con capacidad de voz

# URL pública del servidor (necesaria para que Twilio llame a los webhooks)
# En local: instala ngrok y usa: ngrok http 3000 → copia la URL https://xxxx.ngrok.io
# En producción: tu dominio, ej: https://app.tecnologiasonix.online
BASE_URL=https://TU_DOMINIO_O_NGROK_URL

# SMTP Configuration zohoo
EMAIL_HOST=smtp.zoho.eu
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM_NAME=Tecnologias Onix

# SMTP Configuration resend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_USER=resend
EMAIL_PASS=re_xxxxxxxxxxxx  # Tu API key de Resend
EMAIL_FROM=contacto@tecnologiasonix.online
EMAIL_FROM_NAME=Tecnologias Onix

# Stripe Payment Links
VITE_STRIPE_BASIC_LINK=
VITE_STRIPE_PRO_LINK=
VITE_STRIPE_AGENCY_LINK=

# Stripe Backend Webhook
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Firebase Admin Service Account (JSON stringificado para interactuar con la DB desde el backend)
FIREBASE_SERVICE_ACCOUNT=
